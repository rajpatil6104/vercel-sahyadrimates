{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/images/(.*)",
      "dest": "backend/server.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "backend/server.py"
    },
    {
      "src": "/(.*)",
      "dest": "backend/server.py"
    }
  ],
  "functions": {
    "backend/server.py": {
      "includeFiles": "images/**"
    }
  }
}