
{
  "version": 2,
  "functions": {
    "backend/server.py": {
      "runtime": "@vercel/python"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/server.py"
    },
    {
      "source": "/images/(.*)",
      "destination": "backend/server.py"
    },
    {
      "source": "/seed_data.py",
      "destination": "backend/server.py"
    }
  ]
}
